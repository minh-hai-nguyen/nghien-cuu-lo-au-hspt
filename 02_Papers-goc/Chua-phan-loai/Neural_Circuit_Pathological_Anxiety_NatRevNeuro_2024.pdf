        <article lang="en">
            
            <div class="c-article-header">
                <header>
                    <ul class="c-article-identifiers" data-test="article-identifier">
                        
        <li class="c-article-identifiers__item" data-test="article-category">Review Article</li>
    
    

                        <li class="c-article-identifiers__item">Published: <time datetime="2024-11-27">27 November 2024</time></li>
                    </ul>

                    <h1 class="c-article-title" data-test="article-title" data-article-title="">Neural circuit basis of pathological anxiety</h1>
